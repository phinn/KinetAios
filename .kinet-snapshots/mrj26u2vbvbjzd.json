{"id":"mrj26u2vbvbjzd","convId":"mrfyl4la0lci924u","cwd":"/Users/phinn/Documents/kinet/KinetAiosWin","absPath":"/Users/phinn/Documents/kinet/KinetAiosWin/src/renderer/index.html","tool":"edit_file","contentBefore":"<!DOCTYPE html>\n<html lang=\"zh\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta http-equiv=\"Content-Security-Policy\" content=\"default-src 'self'; frame-src file: http: https:; style-src 'self' 'unsafe-inline'; script-src 'self';\" />\n  <title>KinetAios</title>\n  <link rel=\"stylesheet\" href=\"styles.css\" />\n</head>\n<body>\n  <div id=\"app\">\n    <aside id=\"sidebar\">\n      <div class=\"sb-head\">\n        <div class=\"brand\" id=\"brand\"><span class=\"spark\">✨</span> KinetAios</div>\n        <div class=\"sb-actions\">\n          <button class=\"ghost\" id=\"btn-new\" data-i18n-title=\"sidebar.newSession\" title=\"新建会话\">＋</button>\n          <button class=\"ghost\" id=\"btn-wb\" data-i18n-title=\"wb.open\" title=\"工作台\">📂</button>\n          <button class=\"ghost\" id=\"btn-settings\" data-i18n-title=\"sidebar.settings\" title=\"设置\">⚙</button>\n          <div class=\"sb-more-wrap\">\n            <button class=\"ghost\" id=\"btn-more\" data-i18n-title=\"sidebar.more\" title=\"更多\">⋯</button>\n            <div class=\"sb-more-menu\" id=\"sb-more-menu\">\n              <button class=\"sb-more-item\" id=\"m-dashboard\"><span class=\"sb-mi-ico\">📊</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreDashboard\">仪表盘</span></button>\n              <button class=\"sb-more-item\" id=\"m-files\"><span class=\"sb-mi-ico\">🌐</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreFiles\">文件与预览</span></button>\n              <button class=\"sb-more-item\" id=\"m-arena\"><span class=\"sb-mi-ico\">⚔</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreArena\">Arena 三引擎并跑</span></button>\n              <div class=\"sb-more-sep\"></div>\n              <button class=\"sb-more-item\" id=\"m-memory\"><span class=\"sb-mi-ico\">🧠</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreMemory\">长期记忆</span></button>\n              <button class=\"sb-more-item\" id=\"m-cron\"><span class=\"sb-mi-ico\">📅</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreCron\">定时任务</span></button>\n              <button class=\"sb-more-item\" id=\"m-snap\"><span class=\"sb-mi-ico\">⏪</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreSnapshot\">快照与回滚</span></button>\n              <div class=\"sb-more-sep\"></div>\n              <button class=\"sb-more-item\" id=\"m-pipeline\"><span class=\"sb-mi-ico\">🔗</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.morePipeline\">Pipeline 编排</span></button>\n              <button class=\"sb-more-item\" id=\"m-templates\"><span class=\"sb-mi-ico\">📋</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreTemplates\">模板库</span></button>\n              <button class=\"sb-more-item\" id=\"m-cost\"><span class=\"sb-mi-ico\">💰</span><span class=\"sb-mi-label\" data-i18n=\"sidebar.moreCost\">成本看板</span></button>\n            </div>\n          </div>\n        </div>\n      </div>\n      <ul id=\"conv-list\"></ul>\n      <div class=\"sb-foot\" id=\"sb-foot\">\n        <span class=\"sb-foot-info\">Direct · GLM</span>\n        <span class=\"sb-foot-spacer\"></span>\n        <button class=\"sb-mode ghost\" id=\"sb-mode-toggle\" data-i18n-title=\"sidebar.modeFlat\" title=\"平铺列表\">▤</button>\n      </div>\n    </aside>\n\n    <main id=\"main\">\n      <!-- chat view -->\n      <div id=\"chat-view\" class=\"view active\">\n        <div class=\"chat-head\">\n          <div class=\"ch-row ch-title\">\n            <span class=\"dot ready\" id=\"head-dot\"></span>\n            <span class=\"t\" id=\"head-title\">KinetAios</span>\n            <span class=\"stat\" id=\"head-stat\"></span>\n            <span class=\"status\" id=\"head-status\"></span>\n            <button class=\"ghost\" id=\"btn-clear\" data-i18n-title=\"head.clear\" title=\"清空当前会话\" data-i18n=\"head.clearBtn\">清空</button>\n            <button class=\"ghost\" id=\"btn-del\" data-i18n-title=\"head.delete\" title=\"删除会话\" data-i18n=\"head.deleteBtn\">删除</button>\n            <span class=\"ch-tabs\">\n              <button class=\"cht active\" id=\"tab-chat\" data-i18n=\"tabs.chat\">对话</button>\n              <button class=\"cht\" id=\"tab-files\" data-i18n=\"tabs.files\">文件</button>\n              <button class=\"cht\" id=\"tab-git\" data-i18n=\"tabs.git\">Git</button>\n              <button class=\"cht\" id=\"tab-rules\" data-i18n=\"tabs.rules\">规则</button>\n            </span>\n          </div>\n          <div class=\"ch-row ch-config\">\n            <select id=\"engine-select\" class=\"engine\" data-i18n-title=\"head.engine\" title=\"引擎\">\n              <option value=\"direct\">Kaios (Direct)</option>\n            </select>\n            <input class=\"cwd\" id=\"cwd-input\" data-i18n-title=\"head.cwdTitle\" title=\"工作目录(回车应用或点 📁 选)\" data-i18n-placeholder=\"head.cwdPh\" placeholder=\"工作目录\" />\n            <button class=\"ghost cwd-pick\" id=\"btn-cwd\" data-i18n-title=\"head.pickDir\" title=\"选择目录\">📁</button>\n          </div>\n        </div>\n        <div id=\"chat-content\" class=\"chat-content\">\n          <div id=\"turns\"></div>\n          <div id=\"input\">\n            <div id=\"attach-row\" class=\"attach-row\"></div>\n            <textarea id=\"composer\" rows=\"1\" placeholder=\"给 KinetAios 下达任务…  (Enter 发送,Shift+Enter 换行;可拖入文件)\"></textarea>\n            <div class=\"composer-bar\">\n              <button class=\"tool\" id=\"btn-attach\" data-i18n-title=\"attach.title\" title=\"添加文件(可多选 / 可拖入)\">📎<span class=\"lbl\" data-i18n=\"attach.lbl\">附件</span></button>\n              <input class=\"model-pill\" id=\"model-input\" list=\"model-list\" data-i18n-title=\"model.title\" title=\"模型(Direct 引擎,每会话独立;回车应用)\" data-i18n-placeholder=\"model.ph\" placeholder=\"模型\" />\n              <datalist id=\"model-list\"></datalist>\n              <button class=\"tool\" id=\"btn-skill\" data-i18n-title=\"skill.title\" title=\"选择 Skill(Direct)\">⚡<span class=\"lbl\" data-i18n=\"skill.lbl\">Skill</span></button>\n              <button class=\"tool\" id=\"btn-mcp\" data-i18n-title=\"mcp.title\" title=\"MCP 服务与工具\">🔌<span class=\"lbl\" data-i18n=\"mcp.lbl\">MCP</span></button>\n              <button class=\"tool\" id=\"btn-voice\" data-i18n-title=\"voice.mic\" title=\"语音输入(说,自动转文字)\">🎤<span class=\"lbl\" data-i18n=\"voice.lbl\">语音</span></button>\n              <span class=\"bar-spacer\"></span>\n              <button class=\"primary send\" id=\"btn-send\">发送</button>\n            </div>\n            <div id=\"slash-menu\" class=\"slash-menu\" hidden></div>\n            <div id=\"mcp-menu\" class=\"mcp-menu\" hidden></div>\n            <input type=\"file\" id=\"file-input\" multiple hidden />\n          </div>\n        </div>\n        <div id=\"chat-files-pane\" class=\"chat-files-pane\" hidden>\n          <div class=\"files-head\">\n            <button class=\"ghost\" id=\"btn-pick\" data-i18n-title=\"files.pickDir\" title=\"切换目录\">📁</button>\n            <span class=\"files-cwd\" id=\"files-cwd\"></span>\n            <span class=\"files-spacer\"></span>\n            <div class=\"files-tabs\" id=\"files-tabs\">\n              <button class=\"ftab active\" id=\"ftab-preview\" data-i18n=\"files.tabPreview\">预览</button>\n              <button class=\"ftab\" id=\"ftab-edit\" data-i18n=\"files.tabEdit\">编辑</button>\n            </div>\n            <button class=\"ghost\" id=\"btn-back\" data-i18n-title=\"files.back\" title=\"后退\">←</button>\n            <button class=\"ghost\" id=\"btn-reload\" data-i18n-title=\"files.reload\" title=\"刷新\">⟳</button>\n            <input class=\"files-addr\" id=\"files-addr\" data-i18n-placeholder=\"files.addrPh\" placeholder=\"file:// 或 https:// 或 localhost:8000\" />\n          </div>\n          <div class=\"files-body\">\n            <div class=\"files-tree\" id=\"files-tree\"></div>\n            <div class=\"files-view\">\n              <webview id=\"files-webview\" src=\"about:blank\" partition=\"persist:files\"></webview>\n              <div class=\"files-editor\" id=\"files-editor-pane\" hidden>\n                <textarea id=\"files-editor\" spellcheck=\"false\" data-i18n-placeholder=\"files.editorPh\" placeholder=\"选个文本文件开始编辑…(Ctrl+S 保存)\"></textarea>\n                <div class=\"files-editor-bar\">\n                  <span class=\"fe-status\" id=\"fe-status\"></span>\n                  <span class=\"files-spacer\"></span>\n                  <button class=\"primary\" id=\"btn-save\" data-i18n=\"files.save\">保存</button>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div id=\"files-menu\" class=\"files-menu\" hidden>\n            <div class=\"fm-item\" id=\"fm-open\" data-i18n=\"files.openInBrowser\">在浏览器中打开</div>\n            <div class=\"fm-item\" id=\"fm-edit\" data-i18n=\"files.openInEditor\">在编辑器中打开</div>\n            <div class=\"fm-item\" id=\"fm-copy\" data-i18n=\"files.copyPath\">复制路径</div>\n          </div>\n        </div>\n        <div id=\"chat-git-pane\" class=\"chat-git-pane\" hidden>\n          <div class=\"git-head\">\n            <span class=\"git-branch\" id=\"git-branch\"></span>\n            <span class=\"git-spacer\"></span>\n            <button class=\"ghost\" id=\"btn-git-refresh\" data-i18n-title=\"git.refresh\" title=\"刷新\">⟳</button>\n          </div>\n          <div class=\"git-body\">\n            <div class=\"git-col git-changes\">\n              <div class=\"gb-title\" data-i18n=\"git.changes\">更改</div>\n              <div class=\"gb-list\" id=\"git-changes-list\"></div>\n            </div>\n            <div class=\"git-col git-side\">\n              <div class=\"gb-title\" id=\"git-side-title\" data-i18n=\"git.history\">历史</div>\n              <div class=\"gb-list\" id=\"git-side-list\"></div>\n            </div>\n          </div>\n        </div>\n        <div id=\"chat-rules-pane\" class=\"chat-rules-pane\" hidden>\n          <div class=\"rules-head\">\n            <span class=\"rules-title\" data-i18n=\"rules.title\">项目规则(KINET.md)</span>\n            <span class=\"rules-spacer\"></span>\n            <span class=\"rules-status\" id=\"rules-status\"></span>\n            <button class=\"ghost\" id=\"btn-rules-reload\" data-i18n-title=\"rules.reload\" title=\"重新加载\">⟳</button>\n            <button class=\"primary\" id=\"btn-rules-save\" data-i18n=\"rules.save\">保存</button>\n          </div>\n          <textarea class=\"rules-editor\" id=\"rules-editor\" data-i18n-placeholder=\"rules.ph\" placeholder=\"写在这里的规则会拼到每个会话的 system prompt...\"></textarea>\n        </div>\n      </div>\n\n      <!-- settings view -->\n      <div id=\"settings-view\" class=\"view\">\n        <div id=\"settings\"></div>\n      </div>\n\n      <!-- workbench view(项目卡片总览,每个 cwd 一个项目)-->\n      <div id=\"workbench-view\" class=\"view\">\n        <div id=\"workbench\"></div>\n      </div>\n    </main>\n  </div>\n\n  <!-- shell confirm modal -->\n  <div id=\"modal\">\n    <div class=\"modal-card\">\n      <h3 data-i18n=\"modal.title\">要执行 shell 命令?</h3>\n      <pre id=\"modal-cmd\"></pre>\n      <label style=\"display:block;font-size:12px;color:var(--text-dim);margin:8px 0\"><input type=\"checkbox\" id=\"modal-noask\" style=\"width:auto;margin-right:6px\" /><span data-i18n=\"modal.noask\">不再询问(之后自动放行所有 shell 命令)</span></label>\n      <div class=\"actions\">\n        <button id=\"modal-cancel\" data-i18n=\"common.cancel\">取消</button>\n        <button class=\"primary\" id=\"modal-ok\" data-i18n=\"modal.ok\">执行</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- 输入对话框(Electron 不支持 window.prompt(),用自定义 modal)-->\n  <div id=\"prompt-modal\">\n    <div class=\"modal-card\">\n      <h3 id=\"prompt-title\">改名</h3>\n      <input id=\"prompt-input\" />\n      <div class=\"actions\">\n        <button id=\"prompt-cancel\" data-i18n=\"common.cancel\">取消</button>\n        <button class=\"primary\" id=\"prompt-ok\" data-i18n=\"common.ok\">确定</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- 项目背景编辑器(workbench 卡片「背景」按钮弹出;写 cwd/KINET-CONTEXT.md)-->\n  <div id=\"context-modal\">\n    <div class=\"modal-card cm-card\">\n      <h3 id=\"cm-title\" data-i18n=\"wb.contextTitle\">项目背景(KINET-CONTEXT.md)</h3>\n      <div class=\"cm-cwd\" id=\"cm-cwd\"></div>\n      <textarea class=\"cm-editor\" id=\"cm-editor\" data-i18n-placeholder=\"wb.contextPh\"></textarea>\n      <div class=\"actions\">\n        <span class=\"cm-status\" id=\"cm-status\"></span>\n        <span class=\"cm-spacer\"></span>\n        <button id=\"cm-cancel\" data-i18n=\"common.cancel\">取消</button>\n        <button class=\"primary\" id=\"cm-save\" data-i18n=\"rules.save\">保存</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- 长期记忆面板(🧠 按钮):列表 + scope 切换 + 视图切换(facts/graph)+ 行内编辑/删除 -->\n  <div id=\"memory-modal\">\n    <div class=\"modal-card mm-card\">\n      <div class=\"mm-head\">\n        <h3 data-i18n=\"mem.title\">长期记忆</h3>\n        <div class=\"mm-scope\">\n          <button class=\"ghost active\" id=\"mm-scope-this\" data-i18n=\"mem.scope.this\">当前频道</button>\n          <button class=\"ghost\" id=\"mm-scope-all\" data-i18n=\"mem.scope.all\">全部</button>\n        </div>\n        <div class=\"mm-view\">\n          <button class=\"ghost active\" id=\"mm-view-facts\" data-i18n=\"mem.view.facts\">事实</button>\n          <button class=\"ghost\" id=\"mm-view-graph\" data-i18n=\"mem.view.graph\">图谱</button>\n        </div>\n        <button class=\"ghost\" id=\"mm-graph-viz\" title=\"切换图谱/列表\" style=\"display:none\">🕸️</button>\n        <button class=\"ghost\" id=\"mm-close\">×</button>\n      </div>\n      <div class=\"mm-list\" id=\"mm-list\"></div>\n    </div>\n  </div>\n\n  <!-- 快照面板(⏪ 按钮):write_file/edit_file 写前自动存原文,这里 list + restore -->\n  <div id=\"snapshot-modal\">\n    <div class=\"modal-card mm-card snap-card\">\n      <div class=\"mm-head\">\n        <h3 data-i18n=\"snap.title\">快照与回滚</h3>\n        <div class=\"mm-scope\">\n          <button class=\"ghost active\" id=\"snap-scope-this\" data-i18n=\"snap.scope.this\">当前频道</button>\n          <button class=\"ghost\" id=\"snap-scope-all\" data-i18n=\"snap.scope.all\">本目录全部</button>\n        </div>\n        <button class=\"ghost\" id=\"snap-close\">×</button>\n      </div>\n      <div class=\"mm-list\" id=\"snap-list\"></div>\n    </div>\n  </div>\n\n  <!-- 定时任务面板(📅):cron 表达式 + prompt,匹配时自动起会话 -->\n  <div id=\"cron-modal\">\n    <div class=\"modal-card mm-card cron-card\">\n      <div class=\"mm-head\">\n        <h3 data-i18n=\"cron.title\">定时任务</h3>\n        <button class=\"ghost\" id=\"cron-new\" data-i18n=\"cron.new\">＋ 新任务</button>\n        <button class=\"ghost\" id=\"cron-close\">×</button>\n      </div>\n      <div class=\"mm-list\" id=\"cron-list\"></div>\n    </div>\n  </div>\n\n  <script src=\"app.js\"></script>\n</body>\n</html>\n","ts":1783937268679}