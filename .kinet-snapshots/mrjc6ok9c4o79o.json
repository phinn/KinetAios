>\n          <button class=\"primary\" id=\"btn-save\" data-i18n=\"files.save\">保存</button>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div id=\"files-menu\" class=\"files-menu\" hidden>\n    <div class=\"fm-item\" id=\"fm-open\" data-i18n=\"files.openInBrowser\">在浏览器中打开</div>\n    <div class=\"fm-item\" id=\"fm-edit\" data-i18n=\"files.openInEditor\">在编辑器中打开</div>\n    <div class=\"fm-item\" id=\"fm-copy\" data-i18n=\"files.copyPath\">复制路径</div>\n  </div>\n  <script src=\"files.js\"></script>\n</body>\n</html>\n","ts":1783954057689}